ZENDESK_SUBDOMAIN=your-subdomain

# Legacy auth, still supported during migration:
ZENDESK_EMAIL=you@company.com
ZENDESK_API_KEY=your_api_token

# Preferred auth:
ZENDESK_CLIENT_ID=your_oauth_client_id
ZENDESK_CLIENT_SECRET=your_oauth_client_secret
ZENDESK_REDIRECT_URI=https://localhost/callback
ZENDESK_OAUTH_SCOPES=read write
ZENDESK_OAUTH_TOKEN_PATH=.zendesk_oauth_tokens.json
ZENDESK_TIMEOUT_SECONDS=30
